<div class="container my-5">
  <h1 class="display-5 mb-4 text-center">Add Player</h1>

  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">

      <%= form_with model: @player, url: players_path, local: true, class: "needs-validation" do |f| %>

        <% if @player.errors.any? %>
          <div class="alert alert-danger">
            <h5 class="mb-2">Please fix the following errors:</h5>
            <ul class="mb-0">
              <% @player.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :name, "Player Name", class: "form-label" %>
          <%= f.text_field :name, required: true, class: "form-control" %>
        </div>

        <%= f.submit "Create", class: "btn btn-primary w-100" %>
      <% end %>

      <div class="mt-3 text-center">
        <%= link_to "Back to list", players_path, class: "btn btn-secondary" %>
      </div>

    </div>
  </div>
</div>