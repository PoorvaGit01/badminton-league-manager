<div class="container my-5">
  <h1 class="display-5 mb-4 text-center">Record Match</h1>

  <% if @players.size < 2 %>
    <div class="alert alert-warning text-center">
      You need at least two players. <%= link_to "Add players", new_player_path, class: "alert-link" %>.
    </div>
  <% else %>
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-4">
        <%= form_with model: @match, url: matches_path, local: true, class: "needs-validation" do |f| %>

          <% if @match.errors.any? %>
            <div class="alert alert-danger">
              <h5 class="mb-2">Please fix the following errors:</h5>
              <ul class="mb-0">
                <% @match.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :winner_id, "Winner", class: "form-label" %>
            <%= f.collection_select :winner_id, @players, :id, :name, { prompt: "Select winner" }, { class: "form-select" } %>
          </div>

          <div class="mb-3">
            <%= f.label :loser_id, "Loser", class: "form-label" %>
            <%= f.collection_select :loser_id, @players, :id, :name, { prompt: "Select loser" }, { class: "form-select" } %>
          </div>

          <%= f.submit "Save Match", class: "btn btn-primary w-100" %>
        <% end %>

        <div class="mt-3 text-center">
          <%= link_to "Back to matches", matches_path, class: "btn btn-secondary" %>
        </div>
      </div>
    </div>
  <% end %>
</div>