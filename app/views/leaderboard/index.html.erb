<h1>Leaderboard</h1>
<p>Ranked by wins (then fewer losses, then name).</p>

<table class="table">
  <thead>
    <tr>
      <th>Rank</th>
      <th>Player</th>
      <th>Wins</th>
      <th>Losses</th>
    </tr>
  </thead>
  <tbody>
    <% @players.each_with_index do |player, i| %>
      <tr>
        <td><%= i + 1 %></td>
        <td><%= player.name %></td>
        <td><%= player.matches_won.size %></td>
        <td><%= player.matches_lost.size %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @players.empty? %>
  <p>No players yet. <%= link_to "Add a player", new_player_path %>.</p>
<% end %>